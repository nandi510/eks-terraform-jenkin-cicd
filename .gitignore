# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan binary — contains sensitive data
*.binary
tfplan*

# Terraform directories
.terraform/
.terraform.lock.hcl

# Variable files with real values — use .example files instead
terraform.tfvars
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Sensitive outputs
plan_output.txt

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
